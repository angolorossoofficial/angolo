---
import Base from '../layouts/Base.astro';
import Bracket from './Bracket.astro';
import { withBase } from '../lib/url';
interface Props { kicker: string; title: string; body: string; }
const { kicker, title, body } = Astro.props;
---
<Base title={`${title} — Angolo Rosso`} description={body}>
  <section class="ph-page">
    <div class="ph-card wrap" data-reveal>
      <Bracket animate={true} class="ph-frame" />
      <p class="label">{kicker}</p>
      <h1 class="ph-title display">{title}</h1>
      <p class="ph-body">{body}</p>
      <a href={withBase('/')} class="ph-back label">← Torna alla home</a>
    </div>
  </section>
</Base>

<style>
  .ph-page { min-height: 78vh; display: grid; place-items: center; padding-top: 6rem; }
  .ph-card { position: relative; text-align: center; max-width: 640px; padding: clamp(2rem, 5vw, 4rem) 0; }
  .ph-frame { inset: -8px !important; }
  .ph-title { font-size: var(--fs-h1); margin: 1rem 0 1.4rem; }
  .ph-body { font-family: var(--font-read); font-size: 1.15rem; color: var(--bone-dim); line-height: 1.7; margin-bottom: 2rem; }
  .ph-back { color: var(--blood); }
</style>
