---
import { withBase } from '../lib/url';
import Bracket from './Bracket.astro';
---
<section class="hero">
  <div class="hero-bg" data-hero-bg aria-hidden="true">
    <div class="hero-windows"></div>
    <div class="hero-neon"></div>
    <div class="hero-glow"></div>
    <div class="hero-figure"></div>
    <div class="hero-rain"></div>
  </div>
  <Bracket animate={true} class="hero-frame" />

  <div class="hero-content wrap">
    <p class="hero-eyebrow label" data-reveal>Angolo Rosso — Recensioni di Cinema Horror</p>
    <h1 class="hero-title display">
      <span data-reveal style="transition-delay:.05s">Quanto vuoi</span>
      <span data-reveal style="transition-delay:.13s">spingerti</span>
      <span class="red" data-reveal style="transition-delay:.21s">oltre?</span>
    </h1>
    <span class="hero-rule" data-reveal style="transition-delay:.3s"></span>
    <p class="hero-sub" data-reveal style="transition-delay:.38s">
      Ogni categoria nasconde un mondo.<br />
      Sei pronto a <a href={withBase('/recensioni')} class="red hero-link">entrarci?</a>
    </p>
  </div>

  <a href="#categorie" class="hero-scroll label" aria-label="Scorri alle categorie">
    <span>Scendi</span>
    <svg viewBox="0 0 12 28" fill="none" stroke="var(--blood)" stroke-width="2" aria-hidden="true">
      <line x1="6" y1="1" x2="6" y2="23" stroke-linecap="round"/>
      <path d="M1 18 L6 24 L11 18" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; background: var(--void); }
  .hero-bg > * { position: absolute; inset: 0; }

  /* window mullions — building grid behind the glass */
  .hero-windows {
    background:
      repeating-linear-gradient(90deg, transparent 0 19%, rgba(0,0,0,.55) 19% 20%),
      linear-gradient(180deg, #0b0d18 0%, #0a0a12 45%, #07070a 100%);
    opacity: .9;
  }
  /* blue neon tube streak */
  .hero-neon {
    background:
      radial-gradient(60% 7% at 38% 30%, rgba(80,130,255,.55), transparent 70%),
      linear-gradient(95deg, transparent 30%, rgba(70,120,255,.35) 38%, rgba(120,170,255,.6) 41%, transparent 52%);
    filter: blur(1px);
    mix-blend-mode: screen;
    opacity: .8;
  }
  /* red room glow on the right (the door light) */
  .hero-glow {
    background:
      radial-gradient(46% 70% at 82% 52%, rgba(225,6,0,.55), rgba(120,3,3,.18) 45%, transparent 72%);
    mix-blend-mode: screen;
    animation: pulse 6s var(--ease-in-out) infinite;
  }
  /* silhouette figure in the red light */
  .hero-figure {
    left: auto; right: 14%; top: 30%; bottom: 0; width: min(22vw, 320px);
    background: radial-gradient(60% 60% at 50% 35%, rgba(0,0,0,.92), transparent 70%);
    filter: blur(6px);
    opacity: .9;
  }
  /* rain on glass */
  .hero-rain {
    background-image:
      repeating-linear-gradient(101deg, transparent 0 7px, rgba(180,200,255,.05) 7px 8px),
      repeating-linear-gradient(99deg, transparent 0 13px, rgba(255,255,255,.03) 13px 14px);
    mix-blend-mode: screen;
    opacity: .5;
  }

  @keyframes pulse { 0%,100% { opacity: .85; } 50% { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .hero-glow { animation: none; } }

  .hero-frame { inset: clamp(14px, 2.4vw, 34px) !important; z-index: 4; }

  .hero-content { position: relative; z-index: 5; padding-top: 8vh; }
  .hero-eyebrow { margin-bottom: 1.6rem; color: var(--bone-dim); }
  .hero-title {
    font-size: var(--fs-hero);
    display: flex; flex-direction: column;
    text-shadow: 0 4px 40px rgba(0,0,0,.6);
  }
  .hero-title .red { text-shadow: 0 0 30px rgba(225,6,0,.45); }
  .hero-rule {
    display: block; width: clamp(56px, 7vw, 110px); height: 4px;
    background: var(--blood); margin: 1.8rem 0 1.4rem;
    box-shadow: var(--glow-blood);
    transform-origin: left;
  }
  [data-reveal].hero-rule { transform: scaleX(0); }
  [data-reveal].hero-rule.is-in { transform: scaleX(1); }
  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--bone-dim); font-weight: 600; line-height: 1.7;
  }
  .hero-link { position: relative; }
  .hero-link::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: -2px; height: 2px;
    background: var(--blood); transform: scaleX(0); transform-origin: right;
    transition: transform var(--t-fast) var(--ease-out);
  }
  .hero-link:hover::after { transform: scaleX(1); transform-origin: left; }

  .hero-scroll {
    position: absolute; bottom: clamp(1.4rem, 3vw, 2.6rem); left: 50%;
    transform: translateX(-50%); z-index: 5;
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
    color: var(--ash);
  }
  .hero-scroll svg { width: 12px; height: 28px; animation: bob 1.8s var(--ease-in-out) infinite; }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(5px); } }
  @media (prefers-reduced-motion: reduce) { .hero-scroll svg { animation: none; } }
  @media (max-width: 720px) { .hero-scroll { display: none; } .hero-figure { right: 4%; width: 40vw; } }
</style>

<script>
  // subtle parallax on the hero background
  const bg = document.querySelector('[data-hero-bg]') as HTMLElement | null;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (bg && !reduce) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight) bg.style.transform = `translateY(${y * 0.18}px) scale(1.06)`;
    }, { passive: true });
    bg.style.transform = 'scale(1.06)';
  }
</script>
