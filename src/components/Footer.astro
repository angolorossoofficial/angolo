---
import { withBase } from '../lib/url';
import { categories } from '../data/sample.js';
const year = new Date().getFullYear();
---
<footer class="ft">
  <div class="wrap ft-grid">
    <div class="ft-brand">
      <a href={withBase('/')} class="ft-logo" aria-label="Angolo Rosso — home">
        <img src={withBase('/img/logo-mark.png')} alt="" width="42" height="38" />
        <span class="display">Angolo <span class="red">Rosso</span></span>
      </a>
      <p class="ft-claim">Ogni categoria nasconde un mondo.<br /><span class="red">Sei pronto a entrarci?</span></p>
      <div class="ft-socials">
        <a class="ft-social" href="https://www.instagram.com/angolorossoofficial" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none"/>
          </svg>
          <span>@angolorossoofficial</span>
        </a>
        <a class="ft-social" href="https://www.tiktok.com/@angolorossoofficial" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16.5 3c.31 2.03 1.46 3.66 3.5 3.93v2.54c-1.32 0-2.53-.42-3.53-1.09v6.03c0 3.2-2.42 5.59-5.44 5.59A5.44 5.44 0 0 1 5.6 14.6a5.44 5.44 0 0 1 6.72-5.29v2.65a2.83 2.83 0 0 0-1.29-.31 2.86 2.86 0 1 0 2.86 2.86V3h2.61z"/>
          </svg>
          <span>@angolorossoofficial</span>
        </a>
      </div>
    </div>

    <nav class="ft-col" aria-label="Categorie">
      <p class="label">Categorie</p>
      <ul>
        {categories.map((c) => <li><a href={withBase(`/categoria/${c.slug}`)}>{c.title}</a></li>)}
      </ul>
    </nav>

    <nav class="ft-col" aria-label="Sito">
      <p class="label">Il sito</p>
      <ul>
        <li><a href={withBase('/recensioni')}>Archivio</a></li>
        <li><a href={withBase('/news')}>News</a></li>
        <li><a href={withBase('/chi-siamo')}>Chi siamo</a></li>
        <li><a href={withBase('/contatti')}>Contatti</a></li>
        <li><a href={withBase('/privacy')}>Privacy & Cookie</a></li>
        <li><button type="button" class="ft-linkbtn" data-cookie-reopen>Gestisci cookie</button></li>
      </ul>
    </nav>
  </div>

  <div class="wrap ft-base">
    <span>© {year} Angolo Rosso · Recensioni di Cinema Horror</span>
    <span class="ft-made">Sangue, pellicola e pixel</span>
  </div>
  <p class="wrap ft-tmdb">Le immagini dei film provengono da TMDB. Questo prodotto non è approvato o certificato da TMDB.</p>

  <a class="wrap ft-credit" href="https://x3roautomations.it" target="_blank" rel="noopener noreferrer" aria-label="Sito realizzato da X3RO Automations — apre x3roautomations.it in una nuova scheda">
    <span class="ft-credit-txt">Questo sito è realizzato da</span>
    <img class="ft-credit-logo" src={withBase('/img/x3ro-logo.webp')} alt="X3RO Automations" width="150" height="82" loading="lazy" />
  </a>
</footer>

<style>
  .ft { position: relative; z-index: 2; border-top: 1px solid var(--line); background: var(--void-2); padding-top: clamp(3rem, 6vw, 5rem); margin-top: clamp(3rem, 6vw, 6rem); }
  .ft-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: clamp(1.5rem, 4vw, 4rem); padding-bottom: 3rem; }
  .ft-logo { display: flex; align-items: center; gap: 0.6rem; }
  .ft-logo img { width: auto; height: 34px; filter: drop-shadow(0 0 8px var(--blood-deep)); }
  .ft-logo span { font-size: 1.3rem; letter-spacing: 0.12em; }
  .ft-claim { margin-top: 1.1rem; font-size: 0.8rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ash); line-height: 1.9; }
  .ft-socials { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1.2rem; }
  .ft-social { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--bone-dim); font-size: 0.82rem; letter-spacing: 0.06em; transition: color var(--t-fast); }
  .ft-social svg { width: 18px; height: 18px; }
  .ft-social:hover { color: var(--blood); }
  .ft-tmdb { padding-block: 0 1.4rem; font-size: 0.62rem; letter-spacing: 0.08em; color: var(--ash-dim); }
  .ft-col .label { margin-bottom: 1.1rem; }
  .ft-col ul { display: flex; flex-direction: column; gap: 0.55rem; }
  .ft-col a, .ft-linkbtn { font-size: 0.92rem; color: var(--bone-dim); transition: color var(--t-fast), padding-left var(--t-fast); }
  .ft-col a:hover, .ft-linkbtn:hover { color: var(--blood); padding-left: 0.3rem; }
  .ft-linkbtn { font-family: inherit; background: none; border: 0; padding: 0; cursor: pointer; text-align: left; }
  .ft-base { display: flex; justify-content: space-between; gap: 1rem; padding-block: 1.4rem; border-top: 1px solid var(--line); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash-dim); flex-wrap: wrap; }

  /* agency credit — appears in the footer of every page */
  .ft-credit { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.9rem; padding-block: 2.2rem 2.8rem; margin-top: 0.4rem; border-top: 1px solid var(--line); background: color-mix(in srgb, var(--void) 55%, transparent); }
  .ft-credit-txt { font-family: var(--font-ui); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.28em; text-transform: uppercase; color: var(--bone-dim); }
  .ft-credit-logo { height: 52px; width: auto; opacity: 0.95; filter: drop-shadow(0 0 14px rgba(58,107,255,.28)); transition: opacity var(--t-fast), transform var(--t-fast); }
  .ft-credit:hover .ft-credit-txt { color: var(--bone); }
  .ft-credit:hover .ft-credit-logo { opacity: 1; transform: translateY(-2px); }
  @media (max-width: 520px) { .ft-credit-logo { height: 44px; } .ft-credit-txt { font-size: 0.66rem; letter-spacing: 0.2em; } }

  @media (max-width: 700px) { .ft-grid { grid-template-columns: 1fr 1fr; } .ft-brand { grid-column: 1 / -1; } }
</style>
