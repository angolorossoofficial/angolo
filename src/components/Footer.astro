---
import { withBase } from '../lib/url';
import { categories } from '../data/sample.js';
const year = new Date().getFullYear();
---
<footer class="ft">
  <div class="wrap ft-grid">
    <div class="ft-brand">
      <a href={withBase('/')} class="ft-logo" aria-label="Angolo Rosso — home">
        <svg viewBox="0 0 48 48" aria-hidden="true">
          <path d="M24 5 L43 39 H5 Z" fill="none" stroke="var(--blood)" stroke-width="2.4" stroke-linejoin="round"/>
          <circle cx="24" cy="29" r="6.5" fill="none" stroke="var(--blood)" stroke-width="2.4"/>
          <circle cx="24" cy="29" r="1.8" fill="var(--blood)"/>
          <line x1="24" y1="12" x2="24" y2="20" stroke="var(--blood)" stroke-width="2.4" stroke-linecap="round"/>
        </svg>
        <span class="display">Angolo <span class="red">Rosso</span></span>
      </a>
      <p class="ft-claim">Ogni categoria nasconde un mondo.<br /><span class="red">Sei pronto a entrarci?</span></p>
    </div>

    <nav class="ft-col" aria-label="Categorie">
      <p class="label">Categorie</p>
      <ul>
        {categories.map((c) => <li><a href={withBase(`/categoria/${c.slug}`)}>{c.title}</a></li>)}
      </ul>
    </nav>

    <nav class="ft-col" aria-label="Sito">
      <p class="label">Il sito</p>
      <ul>
        <li><a href={withBase('/recensioni')}>Archivio</a></li>
        <li><a href={withBase('/chi-siamo')}>Chi siamo</a></li>
        <li><a href={withBase('/contatti')}>Contatti</a></li>
        <li><a href={withBase('/privacy')}>Privacy & Cookie</a></li>
      </ul>
    </nav>
  </div>

  <div class="wrap ft-base">
    <span>© {year} Angolo Rosso · Recensioni di Cinema Horror</span>
    <span class="ft-made">Sangue, pellicola e pixel</span>
  </div>
</footer>

<style>
  .ft { position: relative; z-index: 2; border-top: 1px solid var(--line); background: var(--void-2); padding-top: clamp(3rem, 6vw, 5rem); margin-top: clamp(3rem, 6vw, 6rem); }
  .ft-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: clamp(1.5rem, 4vw, 4rem); padding-bottom: 3rem; }
  .ft-logo { display: flex; align-items: center; gap: 0.6rem; }
  .ft-logo svg { width: 34px; height: 34px; }
  .ft-logo span { font-size: 1.3rem; letter-spacing: 0.12em; }
  .ft-claim { margin-top: 1.1rem; font-size: 0.8rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ash); line-height: 1.9; }
  .ft-col .label { margin-bottom: 1.1rem; }
  .ft-col ul { display: flex; flex-direction: column; gap: 0.55rem; }
  .ft-col a { font-size: 0.92rem; color: var(--bone-dim); transition: color var(--t-fast), padding-left var(--t-fast); }
  .ft-col a:hover { color: var(--blood); padding-left: 0.3rem; }
  .ft-base { display: flex; justify-content: space-between; gap: 1rem; padding-block: 1.4rem; border-top: 1px solid var(--line); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash-dim); flex-wrap: wrap; }
  @media (max-width: 700px) { .ft-grid { grid-template-columns: 1fr 1fr; } .ft-brand { grid-column: 1 / -1; } }
</style>
