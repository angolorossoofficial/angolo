---
// Ad space. If the redazione has active "Pubblicità" docs in Sanity, their
// banners rotate here (client-side, no rebuild per spin). With none, a discreet
// labelled placeholder holds the layout so a banner drops in without a shift.
import { sponsors } from '../data/sample.js';
interface Props { variant?: 'leaderboard' | 'inline'; }
const { variant = 'leaderboard' } = Astro.props;
const ads = sponsors;
---
<aside class:list={['ad', `ad--${variant}`]} data-reveal aria-label="Spazio pubblicitario">
  <div class="wrap">
    {ads.length > 0 ? (
      <div class="ad-rot" data-ad-rot>
        <span class="ad-tag label">Pubblicità</span>
        {ads.map((a, i) => (
          <a
            class:list={['ad-item', i === 0 && 'is-on']}
            href={a.url}
            target="_blank"
            rel="sponsored noopener noreferrer"
            data-ad-item
            aria-hidden={i === 0 ? undefined : 'true'}
            tabindex={i === 0 ? undefined : -1}
          >
            <picture>
              {a.mobile && <source media="(max-width: 640px)" srcset={`${a.mobile}?w=640&q=75&auto=format`} />}
              <img src={`${a.desktop}?w=1940&q=75&auto=format`} alt={a.alt} loading="lazy" decoding="async" />
            </picture>
          </a>
        ))}
      </div>
    ) : (
      <div class="ad-box">
        <span class="label">Spazio pubblicitario</span>
      </div>
    )}
  </div>
</aside>

<style>
  .ad { padding-block: clamp(1.5rem, 3vw, 2.5rem); }

  /* placeholder (no active banner) */
  .ad-box {
    display: grid; place-items: center;
    border: 1px dashed var(--line); background: color-mix(in srgb, var(--ink) 60%, transparent);
    color: var(--ash-dim);
  }
  .ad--leaderboard .ad-box { aspect-ratio: 970 / 120; max-height: 130px; }
  .ad--inline .ad-box { aspect-ratio: 300 / 100; max-width: 360px; margin-inline: auto; }
  .ad .label { color: var(--ash-dim); }

  /* live rotating banner — the box reserves height so rotation never shifts the page */
  .ad-rot {
    position: relative; overflow: hidden; margin-inline: auto;
    border: 1px solid var(--line); background: var(--void-2);
  }
  .ad--leaderboard .ad-rot { max-width: 970px; aspect-ratio: 970 / 120; }
  .ad--inline .ad-rot { max-width: 360px; aspect-ratio: 300 / 250; }
  @media (max-width: 640px) {
    /* compact format on phones so a wide banner stays legible */
    .ad--leaderboard .ad-rot { max-width: 360px; aspect-ratio: 320 / 100; }
  }

  .ad-item {
    position: absolute; inset: 0; opacity: 0; pointer-events: none;
    transition: opacity var(--t-med) var(--ease-out);
  }
  .ad-item.is-on { opacity: 1; pointer-events: auto; }
  .ad-item picture, .ad-item img { width: 100%; height: 100%; display: block; }
  .ad-item img { object-fit: contain; }

  .ad-tag {
    position: absolute; top: 6px; right: 8px; z-index: 2;
    font-size: 0.54rem; letter-spacing: 0.24em; color: var(--ash-dim);
    background: color-mix(in srgb, var(--void) 70%, transparent); padding: 1px 6px; border-radius: 2px;
    pointer-events: none;
  }
</style>

<script>
  // Rotate active banners: random start, then cross-fade every 8s. Pure
  // presentation — no cookies, no tracking.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('[data-ad-rot]').forEach((rot) => {
    const items = Array.from(rot.querySelectorAll('[data-ad-item]')) as HTMLElement[];
    if (items.length <= 1) return;

    let i = Math.floor(Math.random() * items.length);
    const show = (n: number) => items.forEach((el, k) => {
      const on = k === n;
      el.classList.toggle('is-on', on);
      if (on) el.removeAttribute('aria-hidden'); else el.setAttribute('aria-hidden', 'true');
      el.tabIndex = on ? 0 : -1;
    });
    show(i);

    if (!reduce) {
      setInterval(() => { i = (i + 1) % items.length; show(i); }, 8000);
    }
  });
</script>
