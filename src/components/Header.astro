---
import { withBase } from '../lib/url';
import { categories } from '../data/sample.js';

const nav = [
  { label: 'Home', href: withBase('/') },
  { label: 'Archivio', href: withBase('/recensioni') },
  { label: 'News', href: withBase('/news') },
];
---
<header class="hd" data-header>
  <div class="hd-inner wrap">
    <button class="hd-btn hd-menu" aria-label="Apri il menu" aria-expanded="false" data-menu-open>
      <span></span><span></span><span></span>
    </button>

    <a class="logo" href={withBase('/')} aria-label="Angolo Rosso — home">
      <img class="logo-mark" src={withBase('/img/logo-mark.png')} alt="" width="42" height="38" />
      <span class="logo-text">
        <span class="logo-name">Angolo <span class="red">Rosso</span></span>
        <span class="logo-sub">Recensioni di Cinema Horror</span>
      </span>
    </a>

    <button class="hd-btn hd-search" aria-label="Cerca" aria-expanded="false" aria-controls="site-search" data-search-open>
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--blood)" stroke-width="2">
        <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
</header>

<!-- full-screen menu -->
<nav class="menu" data-menu aria-hidden="true">
  <button class="menu-close hd-btn" aria-label="Chiudi il menu" data-menu-close>
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--bone)" stroke-width="2" aria-hidden="true">
      <line x1="5" y1="5" x2="19" y2="19" stroke-linecap="round"/>
      <line x1="19" y1="5" x2="5" y2="19" stroke-linecap="round"/>
    </svg>
  </button>
  <div class="menu-grid wrap">
    <div class="menu-col">
      <p class="label">Naviga</p>
      <ul class="menu-list menu-list--big">
        {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </div>
    <div class="menu-col">
      <p class="label">Categorie</p>
      <ul class="menu-list menu-list--cats">
        {categories.map((c) => (
          <li><a href={withBase(`/categoria/${c.slug}`)}>{c.title}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <p class="menu-foot label">Ogni categoria nasconde un mondo. <span class="red">Sei pronto a entrarci?</span></p>
</nav>

<!-- search overlay -->
<div class="srch" id="site-search" data-search aria-hidden="true">
  <button class="menu-close hd-btn" aria-label="Chiudi la ricerca" data-search-close>
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--bone)" stroke-width="2" aria-hidden="true">
      <line x1="5" y1="5" x2="19" y2="19" stroke-linecap="round"/>
      <line x1="19" y1="5" x2="5" y2="19" stroke-linecap="round"/>
    </svg>
  </button>
  <form class="srch-form wrap" action={withBase('/recensioni')} method="get">
    <label class="label" for="q">Cerca un film</label>
    <input id="q" name="q" type="search" placeholder="Titolo, regista, anno…" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="srch-sug" aria-autocomplete="list" />
    <p class="srch-hint label">Premi invio per cercare nell’archivio</p>
    <ul class="srch-sug" id="srch-sug" data-srch-sug role="listbox" aria-label="Suggerimenti" hidden></ul>
  </form>
</div>

<style>
  .hd {
    position: fixed; top: 0; left: 0; right: 0; z-index: 40;
    transition: background var(--t-fast) var(--ease-out), backdrop-filter var(--t-fast);
  }
  .hd[data-scrolled] {
    background: color-mix(in srgb, var(--void) 82%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .hd-inner {
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding-block: clamp(0.9rem, 1.6vw, 1.4rem);
  }
  .hd-btn { display: grid; place-items: center; width: 44px; height: 44px; transition: transform var(--t-fast); }
  .hd-btn:hover { transform: translateY(-1px); }
  .hd-search { justify-self: end; }
  .hd-search svg { width: 22px; height: 22px; }

  .hd-menu { justify-self: start; gap: 5px; }
  .hd-menu span { display: block; width: 24px; height: 2px; background: var(--blood); transition: transform var(--t-fast); }
  .hd-menu:hover span:nth-child(2) { transform: scaleX(0.6); transform-origin: left; }

  .logo { display: flex; align-items: center; gap: 0.7rem; justify-self: center; }
  /* No glow while the header is transparent — over the bright hero photo the
     red drop-shadow reads as haze. It only earns its glow once the nav bar
     darkens on scroll (see .hd[data-scrolled] .logo-mark below). */
  .logo-mark { width: auto; height: 38px; filter: none; transition: filter var(--t-fast); }
  .hd[data-scrolled] .logo-mark { filter: drop-shadow(0 0 9px var(--blood-deep)); }
  .logo-text { display: flex; flex-direction: column; line-height: 1; }
  .logo-name {
    font-family: var(--font-display); text-transform: uppercase;
    font-size: clamp(1.05rem, 1.6vw, 1.5rem); letter-spacing: 0.14em;
  }
  .logo-sub {
    font-size: 0.56rem; letter-spacing: 0.34em; text-transform: uppercase;
    color: var(--ash); margin-top: 0.32rem; font-weight: 600;
  }

  /* menu + search overlays */
  .menu, .srch {
    position: fixed; inset: 0; z-index: 60;
    background: color-mix(in srgb, var(--void) 96%, #000);
    backdrop-filter: blur(6px);
    opacity: 0; visibility: hidden; transform: translateY(-1.5%);
    transition: opacity var(--t-med) var(--ease-out), transform var(--t-med) var(--ease-out), visibility var(--t-med);
    display: flex; flex-direction: column; justify-content: center;
    /* scroll when the content is taller than the viewport (short/landscape phones) */
    overflow-y: auto; overscroll-behavior: contain;
  }
  .menu.is-open, .srch.is-open { opacity: 1; visibility: visible; transform: none; }
  .menu-close { position: absolute; top: max(clamp(1rem,2vw,1.6rem), env(safe-area-inset-top)); right: var(--pad-x); width: 44px; height: 44px; z-index: 2; }
  /* On short or narrow viewports, top-align + let it scroll (centered content
     would clip its top and be unreachable) and bring the foot into flow. */
  @media (max-height: 760px), (max-width: 720px) {
    .menu, .srch {
      justify-content: flex-start;
      padding-top: max(5rem, calc(env(safe-area-inset-top) + 4.5rem));
      padding-bottom: max(2rem, env(safe-area-inset-bottom));
    }
    /* .menu prefix beats the later plain `.menu-foot { position:absolute }` */
    .menu .menu-foot { position: static; margin-top: 2.4rem; }
  }
  .menu-close svg { width: 24px; height: 24px; }

  .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem,6vw,6rem); }
  .menu-col .label { margin-bottom: 1.4rem; }
  .menu-list--big a {
    font-family: var(--font-display); text-transform: uppercase;
    font-size: clamp(2.4rem, 7vw, 5rem); line-height: 1.02; letter-spacing: 0.01em;
    display: inline-block; transition: color var(--t-fast), transform var(--t-fast);
  }
  .menu-list--cats { columns: 2; column-gap: 2rem; }
  .menu-list--cats a {
    font-family: var(--font-ui); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.16em; font-size: 1rem; padding-block: 0.75rem; min-height: 44px; display: flex; align-items: center;
    transition: color var(--t-fast), padding-left var(--t-fast);
  }
  .menu-list a:hover { color: var(--blood); }
  .menu-list--cats a:hover { padding-left: 0.5rem; }
  .menu-list--big a:hover { transform: translateX(0.4rem); }
  .menu-list li { margin-bottom: 0.4rem; }
  .menu-foot { position: absolute; bottom: clamp(1.4rem,3vw,2.4rem); left: var(--pad-x); }

  .srch-form { display: flex; flex-direction: column; gap: 1rem; }
  .srch-form input {
    background: transparent; border: none; border-bottom: 2px solid var(--line);
    color: var(--bone); font-family: var(--font-display); text-transform: uppercase;
    font-size: clamp(1.8rem, 6vw, 4rem); padding: 0.4rem 0; outline: none;
    transition: border-color var(--t-fast);
  }
  .srch-form input::placeholder { color: var(--ash-dim); }
  .srch-form input:focus { border-color: var(--blood); }
  .srch-hint { margin-top: 0.4rem; }

  /* live title suggestions (typo-tolerant).
     :global() on the item selectors — the <a>/<span>/<li> are created in JS
     (no astro cid), so scoped selectors would miss them. */
  .srch-sug { margin-top: 1.4rem; display: flex; flex-direction: column; max-height: 44vh; overflow-y: auto; }
  .srch-sug[hidden] { display: none; }
  .srch-sug :global(a) {
    display: flex; align-items: baseline; gap: 0.9rem; flex-wrap: wrap;
    padding: 0.75rem 0.2rem; border-bottom: 1px solid var(--line);
    transition: color var(--t-fast), padding-left var(--t-fast);
  }
  .srch-sug :global(a:hover), .srch-sug :global(a:focus-visible) { color: var(--blood); padding-left: 0.4rem; }
  .srch-sug :global(.s-title) { font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.04em; font-size: clamp(1.1rem, 2.4vw, 1.7rem); line-height: 1; }
  .srch-sug :global(.s-meta) { font: 600 0.68rem var(--font-ui); letter-spacing: 0.16em; text-transform: uppercase; color: var(--ash); }
  .srch-sug :global(.srch-nores) { margin-top: 1.4rem; color: var(--ash); font-family: var(--font-read); font-style: italic; font-size: 1rem; }

  @media (max-width: 720px) {
    .logo-sub { display: none; }
    .menu-grid { grid-template-columns: 1fr; gap: 2.4rem; }
    .menu-list--cats { columns: 1; }
  }
  @media (max-width: 520px) { .logo-name { font-size: 1.05rem; letter-spacing: 0.1em; } }
</style>

<script>
  const root = document.documentElement;
  const hd = document.querySelector('[data-header]');
  const menu = document.querySelector('[data-menu]');
  const srch = document.querySelector('[data-search]');

  const menuBtn = document.querySelector('[data-menu-open]');
  const searchBtn = document.querySelector('[data-search-open]');
  let lastTrigger: HTMLElement | null = null;
  const setOpen = (el: Element | null, open: boolean, trigger?: HTMLElement) => {
    if (!el) return;
    if (open) lastTrigger = trigger || (document.activeElement as HTMLElement);
    el.classList.toggle('is-open', open);
    el.setAttribute('aria-hidden', String(!open));
    root.style.overflow = open ? 'hidden' : '';
    if (el === menu) menuBtn?.setAttribute('aria-expanded', String(open));
    if (el === srch) searchBtn?.setAttribute('aria-expanded', String(open));
    if (open) {
      // move focus into the panel so keyboard users aren't stranded behind it
      if (el === srch) (el.querySelector('input') as HTMLInputElement | null)?.focus();
      else (el.querySelector('.menu-list a') as HTMLElement | null)?.focus();
    } else {
      // return focus to whatever opened it
      lastTrigger?.focus?.();
      lastTrigger = null;
    }
  };

  document.querySelector('[data-menu-open]')?.addEventListener('click', (e) => setOpen(menu, true, e.currentTarget as HTMLElement));
  document.querySelector('[data-menu-close]')?.addEventListener('click', () => setOpen(menu, false));
  document.querySelector('[data-search-open]')?.addEventListener('click', (e) => setOpen(srch, true, e.currentTarget as HTMLElement));
  document.querySelector('[data-search-close]')?.addEventListener('click', () => setOpen(srch, false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { setOpen(menu, false); setOpen(srch, false); }
  });
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(menu, false)));

  const onScroll = () => hd?.toggleAttribute('data-scrolled', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // --- live, typo-tolerant title suggestions in the full-screen search ---
  const sInput = srch?.querySelector('input') as HTMLInputElement | null;
  const sList = srch?.querySelector('[data-srch-sug]') as HTMLElement | null;
  const BASE = import.meta.env.BASE_URL;
  let INDEX: Array<Record<string, any>> | null = null;
  let indexPromise: Promise<void> | null = null;

  const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

  // Levenshtein distance — powers "wrong letter still finds the film".
  function lev(a: string, b: string) {
    const m = a.length, n = b.length;
    if (!m) return n;
    if (!n) return m;
    let prev = Array.from({ length: n + 1 }, (_, i) => i);
    let cur = new Array(n + 1);
    for (let i = 1; i <= m; i++) {
      cur[0] = i;
      for (let j = 1; j <= n; j++) {
        cur[j] = Math.min(prev[j] + 1, cur[j - 1] + 1, prev[j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1));
      }
      [prev, cur] = [cur, prev];
    }
    return prev[n];
  }

  function scoreItem(it: Record<string, any>, q: string) {
    const t = norm(it.title || '');
    const hay = norm([it.title, it.orig, it.director, it.year].filter(Boolean).join(' '));
    if (t.startsWith(q)) return 100;
    if (t.includes(q)) return 82;
    if (hay.includes(q)) return 60;
    if (q.length >= 3) {
      let best = 99;
      for (const w of t.split(/\s+/)) if (w.length >= 3) best = Math.min(best, lev(w, q));
      if (best <= 2) return 44 - best * 6; // fuzzy: within 2 edits of a title word
    }
    return -1;
  }

  // Fetch once; callers await the SAME in-flight promise so the first
  // keystrokes (while the index still loads) don't render an empty list.
  function ensureIndex() {
    if (!indexPromise) {
      indexPromise = fetch(`${BASE}search-index.json`)
        .then((r) => r.json())
        .then((d) => { INDEX = d; })
        // On a transient failure, clear the memo so the next keystroke retries
        // instead of caching an empty index for the whole session.
        .catch(() => { INDEX = null; indexPromise = null; });
    }
    return indexPromise;
  }

  function renderSug(q: string) {
    if (!sList) return;
    const query = norm(q.trim());
    const expand = (v: boolean) => sInput?.setAttribute('aria-expanded', String(v));
    if (!query || !INDEX) { sList.hidden = true; sList.innerHTML = ''; expand(false); return; }
    const hits = INDEX
      .map((it) => ({ it, sc: scoreItem(it, query) }))
      .filter((x) => x.sc > 0)
      .sort((a, b) => b.sc - a.sc)
      .slice(0, 6);
    sList.innerHTML = '';
    if (!hits.length) {
      const li = document.createElement('li');
      li.className = 'srch-nores';
      li.textContent = 'Nessun titolo simile. Premi invio per cercare in tutto l’archivio.';
      sList.appendChild(li);
      sList.hidden = false; expand(true);
      return;
    }
    for (const { it } of hits) {
      const li = document.createElement('li');
      li.setAttribute('role', 'option');
      const a = document.createElement('a');
      a.href = `${BASE}recensioni/${it.slug}`;
      const title = document.createElement('span');
      title.className = 's-title';
      title.textContent = it.title || ''; // textContent = XSS-safe
      const meta = document.createElement('span');
      meta.className = 's-meta';
      meta.textContent = [it.cat, it.year].filter(Boolean).join(' · ');
      a.append(title, meta);
      li.appendChild(a);
      sList.appendChild(li);
    }
    sList.hidden = false; expand(true);
  }

  sInput?.addEventListener('focus', ensureIndex);
  sInput?.addEventListener('input', () => { ensureIndex().then(() => renderSug(sInput.value)); });
</script>
