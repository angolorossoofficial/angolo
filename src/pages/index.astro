---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CategoryRail from '../components/CategoryRail.astro';
import NuoveRecensioni from '../components/NuoveRecensioni.astro';
import InEvidenza from '../components/InEvidenza.astro';
import AdSlot from '../components/AdSlot.astro';

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Angolo Rosso',
  alternateName: 'Angolo Rosso — Recensioni di Cinema Horror',
  url: 'https://angolorosso.com',
  inLanguage: 'it-IT',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://angolorosso.com/recensioni?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
---
<Base jsonld={jsonld}>
  <Hero />
  <CategoryRail />
  <NuoveRecensioni />
  <AdSlot variant="leaderboard" />
  <InEvidenza />
</Base>
