---
import '@fontsource/anton';
import '@fontsource-variable/archivo';
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/500.css';
import '@fontsource/spectral/600.css';
import '@fontsource/spectral/400-italic.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props { title?: string; description?: string; image?: string; type?: string; jsonld?: object | object[]; }
const {
  title = 'Angolo Rosso — Recensioni di Cinema Horror',
  description = 'Recensioni di cinema horror con un’anima: splatter, psicologici, occulto, indipendenti, dark comedy, classici. Quanto vuoi spingerti oltre?',
  image,
  type = 'website',
  jsonld,
} = Astro.props;
const schemas = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];
// Neutralize `<` (and `>`/`&`) so a CMS field containing `</script>` can't break
// out of the JSON-LD block — hand-rolled equivalent of Astro's define:vars fix.
const ldJson = (s: object) =>
  JSON.stringify(s).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');

const site = Astro.site ?? new URL('https://angolorosso.com');
const canonical = new URL(Astro.url.pathname, site);
// Per-page share image (review poster / news cover) or the cinematic default.
const ogImage = new URL(image ?? '/img/hero-bg.webp', site).href;
---
<!doctype html>
<html lang="it" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#07070a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Angolo Rosso" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    {schemas.map((s) => <script type="application/ld+json" set:html={ldJson(s)} />)}
    <script is:inline>
      // Hide reveal elements synchronously (no flash). Failsafe forces them
      // visible if the reveal module never runs — content can't get stuck hidden.
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js-reveal');
      window.__revealFailsafe = setTimeout(function () {
        document.querySelectorAll('[data-reveal], .bracket--anim').forEach(function (el) { el.classList.add('is-in'); });
      }, 2500);
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Salta al contenuto</a>

    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- atmosphere -->
    <div class="fx fx-ambient" aria-hidden="true" style={`--ambient-img:url(${import.meta.env.BASE_URL}img/hero-bg.webp)`}></div>
    <div class="fx fx-vignette"></div>
    <div class="fx fx-scanlines"></div>
    <div class="fx fx-grain"></div>

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      gsap.registerPlugin(ScrollTrigger);

      if (!reduce) {
        const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((t) => lenis.raf(t * 1000));
        gsap.ticker.lagSmoothing(0);
      }

      // scroll reveals
      const SEL = '[data-reveal], .bracket--anim';
      if (reduce) {
        document.querySelectorAll(SEL).forEach((el) => el.classList.add('is-in'));
      } else {
        ScrollTrigger.batch(SEL, {
          start: 'top 90%',
          onEnter: (els) => els.forEach((el) => el.classList.add('is-in')),
        });
      }
      // reveal module is alive — cancel the head failsafe
      clearTimeout(window.__revealFailsafe);
    </script>
  </body>
</html>
