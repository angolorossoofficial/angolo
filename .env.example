# Sanity content source (public-read dataset — these are configuration, not secrets).
# Defaults are baked into src/data/sample.js, so the build works without a .env.
# Set these only to point the build at a different project/dataset.
PUBLIC_SANITY_PROJECT_ID=82x61wc7
PUBLIC_SANITY_DATASET=production

# --- Netlify Functions ONLY (server-side, NEVER exposed to the browser) -------
# Sanity API token with Editor/Write access, used by netlify/functions to create
# comment + vote documents. Create at https://www.sanity.io/manage -> project
# angolorosso -> API -> Tokens (Editor). Set it in the Netlify dashboard
# (Environment variables), NOT in this repo. Optional overrides default to the
# values above.
# SANITY_WRITE_TOKEN=
# SANITY_PROJECT_ID=82x61wc7
# SANITY_DATASET=production
